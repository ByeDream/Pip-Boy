/* Wasteland Radiation — default Pip-Boy TCSS.
 *
 * Widget topology (themes must NOT change container structure):
 *
 *   Screen
 *     #status-bar              1 row at top
 *     #main                    horizontal
 *       #agent-pane            1fr
 *         #agent-log           1fr (user + assistant dialog)
 *         #agent-log-detail    14 rows (thinking / tool_use / finalize)
 *         #input               1 row
 *       #side-pane             fixed 59 cols
 *         #side-top            auto height
 *           #pipboy-art        fixed height set dynamically (max 30)
 *           #pipboy-clock      fixed ~3 rows
 *         #side-status         auto height
 *         #todo-pane           auto height (max 20)
 *         #app-log             1fr
 */

Screen {
    background: $surface;
    color: $text;
    layers: base overlay;
}

#status-bar {
    dock: top;
    height: 1;
    background: $boost;
    color: $text;
    padding: 0 1;
    text-style: bold;
}

#main {
    layout: horizontal;
    height: 1fr;
}

#agent-pane {
    width: 1fr;
    height: 1fr;
    layout: vertical;
}

#agent-log {
    height: 1fr;
    background: $surface;
    color: $text;
    border: none;
    padding: 0 1;
    scrollbar-gutter: stable;
}

#agent-log-detail {
    height: 14;
    background: $surface;
    color: $text-muted;
    border-top: hkey $accent-darken-2;
    padding: 0 1;
    scrollbar-gutter: stable;
}

#input {
    height: 3;
    border: round $accent;
    background: $surface;
    color: $accent;
}

#input:focus {
    border: round $accent;
    background: $surface;
}

#side-pane {
    width: 59;
    height: 1fr;
    layout: vertical;
    border-left: vkey $accent-darken-2;
    padding: 0 1;
}

#side-top {
    height: auto;
    layout: vertical;
}

#pipboy-art {
    height: auto;
    text-align: center;
    color: $accent;
    text-style: bold;
}

#pipboy-clock {
    height: 3;
    text-align: center;
    color: $accent;
    text-style: bold;
    padding: 1 0 0 0;
}

#side-status {
    height: auto;
    background: $surface;
    color: $text;
    padding: 1 0;
    border-top: hkey $accent-darken-2;
}

#todo-pane {
    height: auto;
    max-height: 20;
    background: $surface;
    color: $text;
    padding: 1 0;
    border-top: hkey $accent-darken-2;
}

#app-log {
    height: 1fr;
    background: $surface;
    color: $text-muted;
    border-top: hkey $accent-darken-2;
    padding: 0 1;
}

.agent-thinking {
    color: $text-muted;
    text-style: italic;
}

.agent-tool {
    color: $accent;
    text-style: dim;
}

.agent-error {
    color: $error;
    text-style: bold;
}

.log-warning {
    color: $warning;
}

.log-error {
    color: $error;
}
