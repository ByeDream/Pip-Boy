/* Vault Amber — amber-on-black retro console TCSS.
 *
 * Widget topology (themes must NOT change container structure):
 *
 *   Screen
 *     #status-bar              1 row at top
 *     #main                    horizontal
 *       #agent-pane            1fr
 *         #agent-log           expand
 *         #input               1 row
 *       #side-pane             fixed 34 cols
 *         #side-top            auto height
 *           #pipboy-banner     auto height
 *           #pipboy-deco       auto height
 *           #pipboy-clock      fixed ~5 rows
 *         #side-status         auto height
 *         #app-log             1fr
 *
 * Theme owns: colors, borders, padding, font weight. Theme does NOT
 * own: dock direction, ratio splits, widget existence. Those are
 * framework invariants the snapshot tests guard.
 */

Screen {
    background: $surface;
    color: $text;
    layers: base overlay;
}

#status-bar {
    dock: top;
    height: 1;
    background: $boost;
    color: $text;
    padding: 0 1;
    text-style: bold;
}

#main {
    layout: horizontal;
    height: 1fr;
}

#agent-pane {
    width: 1fr;
    height: 1fr;
    layout: vertical;
}

#agent-log {
    height: 1fr;
    background: $surface;
    color: $text;
    border: none;
    padding: 0 1;
    scrollbar-gutter: stable;
}

#input {
    height: 3;
    border: heavy $accent;
    background: $surface;
    color: $accent;
}

#input:focus {
    border: heavy $accent;
    background: $surface;
}

#side-pane {
    width: 34;
    height: 1fr;
    layout: vertical;
    border-left: vkey $accent-darken-2;
    padding: 0 1;
}

#side-top {
    height: auto;
    layout: vertical;
    padding: 1 0 0 0;
}

#pipboy-banner {
    height: auto;
    text-align: center;
    color: $accent;
    text-style: bold;
}

#pipboy-deco {
    height: auto;
    text-align: center;
    color: $accent-darken-1;
    padding: 1 0 0 0;
}

#pipboy-clock {
    height: 4;
    text-align: center;
    color: $accent;
    text-style: bold;
    padding: 1 0 0 0;
    border-top: hkey $accent-darken-2;
}

#side-status {
    height: auto;
    background: $surface;
    color: $text;
    padding: 1 0;
    border-top: hkey $accent-darken-2;
}

#app-log {
    height: 1fr;
    background: $surface;
    color: $text-muted;
    border-top: hkey $accent-darken-2;
    padding: 0 1;
}

.agent-thinking {
    color: $text-muted;
    text-style: italic;
}

.agent-tool {
    color: $accent;
    text-style: dim;
}

.agent-error {
    color: $error;
    text-style: bold;
}

.log-warning {
    color: $warning;
}

.log-error {
    color: $error;
}
