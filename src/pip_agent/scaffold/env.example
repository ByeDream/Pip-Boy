# --- Backend Selection ---
# Which agent backend to use: ``codex_cli`` (default) or ``claude_code``.
# Each backend has its own credential and model-tier section below.
BACKEND=codex_cli

# --- Anthropic API (claude_code backend) ---
# Single credential: ANTHROPIC_API_KEY. The auth header Pip-Boy sends is
# decided automatically by ANTHROPIC_BASE_URL:
#   * Empty -> direct to api.anthropic.com using ``x-api-key``.
#   * Set   -> proxy mode; the same key is sent as ``Authorization: Bearer``
#              so it works against OneAPI / claude-relay / corporate gateways
#              out of the box. (This is the path most self-hosted relays
#              actually accept; native ``x-api-key`` is rare on them.)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=               # Leave empty for default (api.anthropic.com)

# --- OpenAI / Codex API (codex_cli backend) ---
# Credentials for the Codex backend. When set, these are injected directly
# into ``CodexOptions(api_key=..., base_url=...)`` and take precedence over
# any ``~/.codex/config.toml`` global configuration.
# Falls back to ``OPENAI_API_KEY`` / ``OPENAI_BASE_URL`` env vars when empty.
# If ALL are empty, the SDK reads ``~/.codex/config.toml`` (e.g. for
# Codex App users who already have a working global setup).
CODEX_API_KEY=
CODEX_BASE_URL=                   # Leave empty for default (api.openai.com)

# --- Web Search (mcp__pip__web_search) ---
# Tavily is the preferred search provider — higher-quality, more relevant
# results than the free alternatives. Sign up at https://tavily.com/ for
# a ``tvly-...`` key (free tier is generous). When this is empty OR Tavily
# errors out (rate limit, invalid key, transport), the tool falls back
# automatically to DuckDuckGo, which requires no key.
TAVILY_API_KEY=

# --- Model Tiers (Codex / default) ---
# Three model names, ordered strongest -> cheapest. Each backend has its
# own tier set. Every call site picks a tier (t0/t1/t2) and resolves
# through the matching table at runtime. Async / background tasks
# (heartbeat, cron, reflect, dream) are pinned to fixed tiers in code.
# Failures on a specific model degrade DOWN the chain (t0 -> t1 -> t2);
# never up.
CODEX_MODEL_T0=gpt-5.5
CODEX_MODEL_T1=gpt-5.4
CODEX_MODEL_T2=gpt-5.4-mini

# Reasoning effort for the Codex backend. Controls how much "thinking"
# the model does per turn. Valid: none, minimal, low, medium, high, xhigh.
# Higher effort -> more reasoning tokens -> better quality but higher cost
# and latency. Reasoning tokens are billed at the output-token rate.
# Default: medium (balanced quality/cost). Use "low" for fast interactive
# tasks, "high" or "xhigh" for complex debugging or planning.
CODEX_REASONING_EFFORT=medium

# --- Model Tiers (Claude) ---
# Used when BACKEND=claude_code.
CLAUDE_MODEL_T0=claude-opus-4-7
CLAUDE_MODEL_T1=claude-sonnet-4-6
CLAUDE_MODEL_T2=claude-haiku-4-5

# --- WeCom (企业微信智能机器人) ---
WECOM_BOT_ID=
WECOM_BOT_SECRET=

# --- Debug ---
# VERBOSE only controls the stdlib ``logging`` threshold:
#   false (default) = root at WARNING   (quiet; errors still visible)
#   true            = root at INFO + ``pip_agent.*`` at DEBUG
#                      (firehose: scheduler ticks, memory pipeline, hooks;
#                       third-party libs ride root at INFO, so no
#                       DEBUG-level HTTP/MCP floods)
# Streaming agent replies and [tool: ...] traces are always on regardless.
VERBOSE=false

# --- Heartbeat ---
# If an agent's ``.pip/HEARTBEAT.md`` exists (root agent's workspace ``.pip/``,
# or any sub-agent's ``<project>/.pip/``), its contents are injected as a
# <heartbeat> inbound on this cadence during the active window. Set interval
# to 0 to disable without deleting the file. Heartbeat is NOT part of the
# memory pipeline (reflect runs on PreCompact / /exit only).
HEARTBEAT_INTERVAL=1800           # Seconds between heartbeat injections
HEARTBEAT_ACTIVE_START=9          # Local hour (0-23) when heartbeats begin
HEARTBEAT_ACTIVE_END=22           # Local hour (0-23) when heartbeats stop

# --- Dream (memory consolidation) ---
# Dream runs L2 consolidate + L3 axiom distillation over already-persisted
# observations (which the reflect stage writes from PreCompact / /exit).
# All three gates must be satisfied on the same scheduler tick:
#   1. Local clock within [DREAM_HOUR_START, DREAM_HOUR_END)
#   2. observations.jsonl has at least DREAM_MIN_OBSERVATIONS entries
#   3. No user/channel activity for at least DREAM_INACTIVE_MINUTES
# Set DREAM_HOUR_START == DREAM_HOUR_END to disable Dream entirely.
DREAM_HOUR_START=2                # Local hour (0-23) idle-window begins
DREAM_HOUR_END=5                  # Local hour (0-23) idle-window ends
DREAM_MIN_OBSERVATIONS=20         # Minimum obs count before consolidate fires
DREAM_INACTIVE_MINUTES=30         # Minutes of inactivity required

# --- Plugin Marketplaces ---
# Comma-separated marketplaces auto-registered at host cold-start so a fresh
# checkout has plugins discoverable via ``/plugin search`` without a manual
# ``/plugin marketplace add`` step. Each entry accepts any spec the bundled
# CLI's ``plugin marketplace add`` accepts (``owner/repo``, https git URL,
# or local path). Existing entries are detected via ``plugin marketplace list
# --json`` and skipped, so the cold-start cost after the first boot is one
# subprocess spawn (~2 s). First-time clones can take ~15 s per spec.
# Set to empty to disable bootstrap (Pip-Boy then matches Claude Code's
# default of zero pre-configured marketplaces).
BOOTSTRAP_MARKETPLACES=anthropics/claude-plugins-official

# Timeout (seconds) for plugin / marketplace operations that hit the
# network (``marketplace add`` git clone, ``plugin install`` clone +
# ``npm``/``uv`` dependency fetch, ``marketplace update``). Local-only
# operations (``list``, ``search``, ``uninstall``, ``enable``,
# ``disable``) ignore this and keep a static 30 s cap. Raise to e.g.
# 600 on very slow proxy / VPN paths; lower if you prefer to fail fast.
PLUGIN_NETWORK_TIMEOUT_SEC=180

# --- Web Tools ---
# When true, register Pip-Boy's own MCP web_search / web_fetch on both
# backends.  On Claude Code this also disables the native WebSearch /
# WebFetch (useful when the upstream proxy rejects the native tool schema).
# On Codex, native web tools are always available — this adds MCP
# alternatives alongside them.  Default false: both backends use their
# own native web tools only.
USE_CUSTOM_WEB_TOOLS=false

# --- ASCII Art Animation ---
# Seconds between frame advances for multi-frame ascii_art_N.txt sequences.
# Set to 0 to disable animation (single-frame themes are unaffected).
ART_ANIM_INTERVAL=2.0

