# --- Anthropic API ---
# Use ANTHROPIC_API_KEY for direct Anthropic, or ANTHROPIC_AUTH_TOKEN for proxy
# gateways that require ``Authorization: Bearer``. If ANTHROPIC_BASE_URL is set,
# any credential is promoted to bearer-token mode automatically (Claude Code's
# own convention — Pip-Boy matches it so direct-SDK calls like ``reflect`` use
# the same auth as the agent).
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=               # Leave empty for default (api.anthropic.com)

# --- Model Tiers ---
# Three model names, ordered strongest -> cheapest. The agent never sees
# concrete model names: every call site picks a tier (t0/t1/t2) and resolves
# through this table at runtime. Async / background tasks (heartbeat, cron,
# reflect, dream) are pinned to fixed tiers in code. Failures on a specific
# model degrade DOWN the chain (t0 -> t1 -> t2); never up.
MODEL_T0=claude-opus-4-7
MODEL_T1=claude-sonnet-4-6
MODEL_T2=claude-sonnet-4-6

# --- WeCom (企业微信智能机器人) ---
WECOM_BOT_ID=
WECOM_BOT_SECRET=

# --- Debug ---
# VERBOSE only controls the stdlib ``logging`` threshold:
#   false (default) = root at WARNING   (quiet; errors still visible)
#   true            = root at INFO + ``pip_agent.*`` at DEBUG
#                      (firehose: scheduler ticks, memory pipeline, hooks;
#                       third-party libs ride root at INFO, so no
#                       DEBUG-level HTTP/MCP floods)
# Streaming agent replies and [tool: ...] traces are always on regardless.
VERBOSE=false

# --- Heartbeat ---
# If an agent's ``.pip/HEARTBEAT.md`` exists (root agent's workspace ``.pip/``,
# or any sub-agent's ``<project>/.pip/``), its contents are injected as a
# <heartbeat> inbound on this cadence during the active window. Set interval
# to 0 to disable without deleting the file. Heartbeat is NOT part of the
# memory pipeline (reflect runs on PreCompact / /exit only).
HEARTBEAT_INTERVAL=1800           # Seconds between heartbeat injections
HEARTBEAT_ACTIVE_START=9          # Local hour (0-23) when heartbeats begin
HEARTBEAT_ACTIVE_END=22           # Local hour (0-23) when heartbeats stop

# --- Dream (memory consolidation) ---
# Dream runs L2 consolidate + L3 axiom distillation over already-persisted
# observations (which the reflect stage writes from PreCompact / /exit).
# All three gates must be satisfied on the same scheduler tick:
#   1. Local clock within [DREAM_HOUR_START, DREAM_HOUR_END)
#   2. observations.jsonl has at least DREAM_MIN_OBSERVATIONS entries
#   3. No user/channel activity for at least DREAM_INACTIVE_MINUTES
# Set DREAM_HOUR_START == DREAM_HOUR_END to disable Dream entirely.
DREAM_HOUR_START=2                # Local hour (0-23) idle-window begins
DREAM_HOUR_END=5                  # Local hour (0-23) idle-window ends
DREAM_MIN_OBSERVATIONS=20         # Minimum obs count before consolidate fires
DREAM_INACTIVE_MINUTES=30         # Minutes of inactivity required

# --- Plugin Marketplaces ---
# Comma-separated marketplaces auto-registered at host cold-start so a fresh
# checkout has plugins discoverable via ``/plugin search`` without a manual
# ``/plugin marketplace add`` step. Each entry accepts any spec the bundled
# CLI's ``plugin marketplace add`` accepts (``owner/repo``, https git URL,
# or local path). Existing entries are detected via ``plugin marketplace list
# --json`` and skipped, so the cold-start cost after the first boot is one
# subprocess spawn (~2 s). First-time clones can take ~15 s per spec.
# Set to empty to disable bootstrap (Pip-Boy then matches Claude Code's
# default of zero pre-configured marketplaces).
BOOTSTRAP_MARKETPLACES=anthropics/claude-plugins-official

# Timeout (seconds) for plugin / marketplace operations that hit the
# network (``marketplace add`` git clone, ``plugin install`` clone +
# ``npm``/``uv`` dependency fetch, ``marketplace update``). Local-only
# operations (``list``, ``search``, ``uninstall``, ``enable``,
# ``disable``) ignore this and keep a static 30 s cap. Raise to e.g.
# 600 on very slow proxy / VPN paths; lower if you prefer to fail fast.
PLUGIN_NETWORK_TIMEOUT_SEC=180

# --- ASCII Art Animation ---
# Seconds between frame advances for multi-frame ascii_art_N.txt sequences.
# Set to 0 to disable animation (single-frame themes are unaffected).
ART_ANIM_INTERVAL=3.0

