# --- Anthropic API ---
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=              # Leave empty for default (api.anthropic.com)

# --- Web Search ---
SEARCH_API_KEY=                  # Tavily API key; leave empty to use DuckDuckGo fallback

# --- WeCom (企业微信智能机器人) ---
WECOM_BOT_ID=
WECOM_BOT_SECRET=

# --- Debug ---
VERBOSE=true
PROFILER_ENABLED=false

# --- Memory Pipeline ---
REFLECT_TRANSCRIPT_THRESHOLD=10   # New transcripts needed to trigger reflection
TRANSCRIPT_RETENTION_DAYS=7       # Days to keep reflected transcripts
DREAM_HOUR=2                      # Local hour (0-23) for Dream (consolidate+axioms)
DREAM_MIN_OBSERVATIONS=20         # Minimum observations before Dream can run
DREAM_INACTIVE_MINUTES=30         # Agent idle time required for Dream

# --- Per-Agent Settings ---
# MODEL, MAX_TOKENS, COMPACT_THRESHOLD, and COMPACT_MICRO_AGE are now
# configured per-agent in .pip/agents/*/persona.md (YAML frontmatter).
# See .pip/agents/pip-boy/persona.md for the default agent configuration.
