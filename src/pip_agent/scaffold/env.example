# --- Anthropic API ---
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=              # Leave empty for default (api.anthropic.com)

# --- Model ---
MODEL=claude-sonnet-4-6
MAX_TOKENS=8096

# --- Web Search ---
SEARCH_API_KEY=                  # Tavily API key; leave empty to use DuckDuckGo fallback

# --- Agent ---
COMPACT_THRESHOLD=50000          # Token count to trigger conversation compaction
COMPACT_MICRO_AGE=3              # Micro-conversation expiry rounds

# --- WeCom (企业微信智能机器人) ---
WECOM_BOT_ID=
WECOM_BOT_SECRET=

# --- Debug ---
VERBOSE=true
PROFILER_ENABLED=false
